# =============================================================================
# Ovature Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Required - Google APIs
# -----------------------------------------------------------------------------
# Google Service Account credentials (JSON format, single line)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant access to: Google Sheets API, Google Drive API
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Sheet ID for the global production registry
REGISTRY_SHEET_ID=your-registry-sheet-id

# -----------------------------------------------------------------------------
# Optional - Email (Resend)
# -----------------------------------------------------------------------------
# API key from https://resend.com
# Required for: sendShowReport, sendCastNotes, sendReport, etc.
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Optional - SMS (Twilio)
# -----------------------------------------------------------------------------
# Credentials from https://console.twilio.com
# Required for: SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Optional - AI Features (Anthropic)
# -----------------------------------------------------------------------------
# API key from https://console.anthropic.com
# Required for: chatProxy, lookupShowCast, lookupShowScenes, generateAuditionMaterials
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Optional - Platform Administration
# -----------------------------------------------------------------------------
# JSON array of admin email addresses for cross-production management
# Example: ["admin@example.com","superuser@example.com"]
PLATFORM_ADMINS=[]
